# Application/runtime values (intended for CVM encrypted secrets)
ADMIN_API_KEY=replace-with-at-least-32-bytes-admin-key
OBLIVIOUS_NODE_IMAGE=ghcr.io/your-org/oblivious-node@sha256:replace-with-real-digest
DSTACK_SOCKET_PATH=/var/run/dstack.sock

# Optional for phase3 (Sepolia) compose
RETH_IMAGE=ghcr.io/paradigmxyz/reth@sha256:replace-with-real-digest
LIGHTHOUSE_IMAGE=sigp/lighthouse@sha256:replace-with-real-digest
JWT_INIT_IMAGE=alpine@sha256:replace-with-real-digest
ETH_NETWORK=sepolia
LIGHTHOUSE_CHECKPOINT_SYNC_URL=https://checkpoint-sync.sepolia.ethpandaops.io
RETH_RPC_URL=http://reth:8546
INITIAL_SYNC_START_BLOCK=1
NODE_SYNC_MODE=roots-and-witness
