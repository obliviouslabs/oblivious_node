# Registry bootstrap secrets for CVM pre-launch (only needed for private images)
# These are encrypted and consumed by Phala pre-launch logic.
# Keep this file empty if all images are public.

# Docker Hub / GHCR
# DSTACK_DOCKER_USERNAME=
# DSTACK_DOCKER_PASSWORD=
# DSTACK_DOCKER_REGISTRY=ghcr.io

# AWS ECR
# DSTACK_AWS_ACCESS_KEY_ID=
# DSTACK_AWS_SECRET_ACCESS_KEY=
# DSTACK_AWS_REGION=
# DSTACK_AWS_ECR_REGISTRY=
# DSTACK_AWS_SESSION_TOKEN=
